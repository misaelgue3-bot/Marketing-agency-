# Copy this file to .env and fill in your values.
# The site works without any of these — they just unlock extra features.

# Port the server listens on
PORT=3000

# Admin dashboard login (http://yoursite.com/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# --- AI agent team ---
# The four agents (Sofía, Marco, Lucía, Valen) run on either provider:
#   Claude (platform.claude.com) — best quality, recommended for campaigns.
#   Groq   (console.groq.com)   — very fast, generous free tier.
# Set one key or both. With both, Claude is used unless AI_PROVIDER=groq.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Optional: force a provider ("claude" or "groq") / pick the Groq model
AI_PROVIDER=
GROQ_MODEL=llama-3.3-70b-versatile

# Higgsfield (https://cloud.higgsfield.ai) lets Valen generate real ad
# images with the Soul model. Optional — campaigns work without it.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# --- Telegram bot (Sofía answers live, 24/7) ---
# Create a bot in 2 minutes: message @BotFather in Telegram → /newbot →
# paste the token here. Customers who message the bot get answered by
# Sofía automatically; each new person becomes a lead in the admin.
TELEGRAM_BOT_TOKEN=
# Optional: your own chat id (send /id to your bot to see it) — you get an
# instant Telegram alert for every new lead.
TELEGRAM_OWNER_CHAT_ID=

# --- Autopilot ---
# Each switch is independent. Messages the agents write appear in the
# admin Outbox; with SMTP configured they are emailed automatically,
# without SMTP they wait there as drafts for you to copy & send.
AUTO_CAMPAIGNS=false        # fresh monthly campaign per active client
AUTO_LEAD_REPLY=false       # Sofía answers every new website lead
AUTO_MONTHLY_CHECKINS=false # Sofía checks in with each client on the 1st
AUTO_PAYMENT_REMINDERS=false# Sofía nudges clients unpaid by the 7th
WEEKLY_DIGEST=false         # Monday business summary to NOTIFY_EMAIL

# --- Email notifications ---
# Optional: get an email every time someone submits the contact form.
# Works with Gmail (use an App Password), or any SMTP provider.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=misaelgue3@gmail.com
