# Copy this file to .env and fill in your values.
# The site works without any of these — they just unlock extra features.

# Port the server listens on
PORT=3000

# Admin dashboard login (http://yoursite.com/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# --- AI agent team ---
# The four agents (Sofía, Marco, Lucía, Valen) run on either provider:
#   Claude (platform.claude.com) — best quality, recommended for campaigns.
#   Groq   (console.groq.com)   — very fast, generous free tier.
# Set one key or both. With both, Claude is used unless AI_PROVIDER=groq.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Optional: force a provider ("claude" or "groq") / pick the Groq model
AI_PROVIDER=
GROQ_MODEL=llama-3.3-70b-versatile

# Higgsfield (https://cloud.higgsfield.ai) lets Valen generate real ad
# images with the Soul model. Optional — campaigns work without it.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Set to true and every active client automatically gets a fresh campaign
# at the start of each month, with no input from you.
AUTO_CAMPAIGNS=false

# --- Email notifications ---
# Optional: get an email every time someone submits the contact form.
# Works with Gmail (use an App Password), or any SMTP provider.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=misaelgue3@gmail.com
